# ─── Backend ───────────────────────────────────────────────────────────────
# MongoDB bağlantı adresi (MongoDB Atlas için şu formatta kullanın):
# mongodb+srv://<kullanici>:<sifre>@cluster0.xxxxx.mongodb.net/<veritabani>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/kulupler_birligi

# Express sunucu portu
PORT=5000

# Admin API endpoint'ini korumak için kullanılan gizli anahtar
# Canlıda uzun ve rastgele bir değer kullanın (örn: openssl rand -hex 32)
ADMIN_API_KEY=your_super_secret_admin_key_here

# İzin verilen frontend adresi (CORS)
CLIENT_URL=http://localhost:5173

# ─── Frontend (Vite) ───────────────────────────────────────────────────────
# Bu değişken frontend build sırasında kullanılır.
# Vite sadece VITE_ önekiyle başlayan değişkenleri bundle'a dahil eder.
VITE_API_URL=http://localhost:5000
